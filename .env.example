# Database
DATABASE_URL=postgresql+asyncpg://poster:poster@localhost:5432/linkedin_ai_poster

# Google Gemini (for caption & image generation)
GEMINI_API_KEY=your-gemini-api-key-here

# LinkedIn API
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_URN=urn:li:person:your-person-id

# Pipeline settings
AUTO_APPROVE=false
FETCH_WINDOW_HOURS=48
MIN_SCORE_TO_POST=0.35

# Logging
LOG_LEVEL=INFO

# Image fetching (SerpAPI - https://serpapi.com/manage-api-key)
SERPAPI_KEY=your-serpapi-key-here
IMAGE_COUNT=3

# Scheduling (posts every N days)
POST_INTERVAL_DAYS=3
DAILY_RUN_HOUR=16
DAILY_RUN_MINUTE=50
TIMEZONE=Asia/Kolkata
